<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Notas.Views.MainPage"
             Title="Aplicacion de notas"
              BackgroundColor="#00335C">
    <Grid RowDefinitions="Auto, Auto, *">

        <!-- Header -->
        <StackLayout Grid.Row="0" Padding="20,28,20,0">
            <Label Text="Mis Notas ✨"
                   FontSize="34"
                   FontAttributes="Bold"
                   TextColor="#FFFFFF"/>
            <Label Text="{Binding ListaNotas.Count, StringFormat='{0} notas'}"
                   FontSize="14"
                   TextColor="#A78BFA"
                   Margin="0,2,0,16"/>
        </StackLayout>

        <!-- Barra de búsqueda -->
        <Frame Grid.Row="1"
               BackgroundColor="#16213E"
               BorderColor="#A78BFA"
               CornerRadius="14"
               Padding="4,0"
               Margin="16,0,16,10"
               HasShadow="False">
            <SearchBar Placeholder="🔍  Buscar notas..."
                       Text="{Binding Busqueda}"
                       BackgroundColor="Transparent"
                       PlaceholderColor="#6B7280"
                       TextColor="#FFFFFF"
                       CancelButtonColor="#A78BFA"/>
        </Frame>

        <!-- Grid absoluto para lista + FAB -->
        <Grid Grid.Row="2">

            <CollectionView ItemsSource="{Binding ListaNotas}"
                            Margin="16,0,16,90">

                <CollectionView.EmptyView>
                    <StackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Padding="40" Spacing="12">
                        <Label Text="📒" FontSize="72" HorizontalOptions="Center"/>
                        <Label Text="Sin notas aún"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="#FFFFFF"
                               HorizontalOptions="Center"/>
                        <Label Text="Toca el botón + para escribir tu primera nota"
                               FontSize="14" TextColor="#A78BFA"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,5">
                            <Frame BackgroundColor="#16213E"
                                   BorderColor="#A78BFA"
                                   CornerRadius="16"
                                   Padding="0"
                                   HasShadow="False">

                                <Frame.Shadow>
                                    <Shadow Brush="#A78BFA"
                                            Offset="0,3"
                                            Radius="10"
                                            Opacity="0.2"/>
                                </Frame.Shadow>

                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditarCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Frame.GestureRecognizers>

                                <Grid ColumnDefinitions="7, *">

                                    <!-- Barra lateral degradada por pin -->
                                    <BoxView Grid.Column="0"
                                             CornerRadius="16,0,0,16"
                                             BackgroundColor="{Binding IsPinned, Converter={x:StaticResource PinColorConverter}}"/>

                                    <StackLayout Grid.Column="1" Padding="14,12" Spacing="5">

                                        <Grid ColumnDefinitions="*, Auto, Auto">

                                            <Label Grid.Column="0"
                                                   Text="{Binding Titulo}"
                                                   FontAttributes="Bold"
                                                   FontSize="16"
                                                   TextColor="#F0ABFC"
                                                   LineBreakMode="TailTruncation"
                                                   VerticalOptions="Center"/>

                                            <Label Grid.Column="1"
                                                   Text="📌"
                                                   FontSize="14"
                                                   VerticalOptions="Center"
                                                   Margin="4,0"
                                                   IsVisible="{Binding IsPinned}"/>

                                            <Button Grid.Column="2"
                                                    Text="🗑"
                                                    BackgroundColor="Transparent"
                                                    TextColor="#F87171"
                                                    FontSize="18"
                                                    WidthRequest="38"
                                                    HeightRequest="38"
                                                    Padding="0"
                                                    VerticalOptions="Center"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EliminarCommand}"
                                                    CommandParameter="{Binding .}"/>
                                        </Grid>

                                        <Label Text="{Binding Contenido}"
                                               FontSize="14"
                                               TextColor="#C4B5FD"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2"/>

                                        <Label Text="{Binding FechaFormateada}"
                                               FontSize="11"
                                               TextColor="#6B7280"
                                               Margin="0,4,0,0"/>

                                    </StackLayout>
                                </Grid>
                            </Frame>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- FAB -->
            <Button Text="+"
                    FontSize="30"
                    FontAttributes="Bold"
                    TextColor="White"
                    WidthRequest="58"
                    HeightRequest="58"
                    CornerRadius="29"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="0,0,24,28"
                    ZIndex="99"
                    Command="{Binding NuevaNotaCommand}">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C3AED" Offset="0.0"/>
                        <GradientStop Color="#EC4899" Offset="1.0"/>
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Shadow>
                    <Shadow Brush="#7C3AED"
                            Offset="0,4"
                            Radius="14"
                            Opacity="0.5"/>
                </Button.Shadow>
            </Button>

        </Grid>
    </Grid>
</ContentPage>