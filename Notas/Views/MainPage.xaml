<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Notas.Views.MainPage"
             Title="Aplicacion de notas">
    <!-- Header estilo iOS -->
    <NavigationPage.TitleView>
        <Label Text="Notas"
               FontSize="22"
               FontAttributes="Bold"
               VerticalOptions="Center"
               TextColor="Black"/>
    </NavigationPage.TitleView>

    <Grid RowDefinitions="Auto, *">

        <!-- Panel de edición superior -->
        <Frame Grid.Row="0"
               BackgroundColor="White"
               BorderColor="#E0E0E0"
               CornerRadius="16"
               Padding="16"
               Margin="16,16,16,8"
               HasShadow="True">

            <StackLayout Spacing="10">

                <Entry Placeholder="Título"
                       Text="{Binding Titulo}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#1C1C1E"
                       PlaceholderColor="#C7C7CC"
                       BackgroundColor="Transparent"/>

                <BoxView HeightRequest="1"
                         BackgroundColor="#E0E0E0"/>

                <Editor Placeholder="Escribe tu nota aquí..."
                        Text="{Binding Contenido}"
                        FontSize="15"
                        TextColor="#3A3A3C"
                        PlaceholderColor="#C7C7CC"
                        BackgroundColor="Transparent"
                        HeightRequest="100"
                        AutoSize="TextChanges"/>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">

                    <Button Grid.Column="0"
                            Text="✓  Guardar"
                            BackgroundColor="#34C759"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="44"
                            Command="{Binding GuardarCommand}"
                            IsVisible="{Binding ModoGuardar}"/>

                    <Button Grid.Column="0"
                            Text="✎  Actualizar"
                            BackgroundColor="#FF9500"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="44"
                            Command="{Binding ActualizarCommand}"
                            IsVisible="{Binding ModoEdicion}"/>

                    <Button Grid.Column="1"
                            Text="✕  Cancelar"
                            BackgroundColor="#E5E5EA"
                            TextColor="#3A3A3C"
                            FontAttributes="Bold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="44"
                            Command="{Binding CancelarCommand}"
                            IsVisible="{Binding ModoEdicion}"/>

                </Grid>

            </StackLayout>
        </Frame>

        <!-- Lista de notas -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding ListaNotas}"
                        Margin="16,0,16,16">

            <CollectionView.EmptyView>
                <StackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Padding="40">
                    <Label Text="📝"
                           FontSize="60"
                           HorizontalOptions="Center"/>
                    <Label Text="Sin notas aún"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#8E8E93"
                           HorizontalOptions="Center"/>
                    <Label Text="Toca el campo de arriba para crear tu primera nota"
                           FontSize="14"
                           TextColor="#C7C7CC"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </StackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="White"
                           BorderColor="Transparent"
                           CornerRadius="14"
                           Padding="16"
                           Margin="0,5"
                           HasShadow="True">

                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto">

                            <!-- Título -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Titulo}"
                                   FontAttributes="Bold"
                                   FontSize="16"
                                   TextColor="#1C1C1E"
                                   LineBreakMode="TailTruncation"/>

                            <!-- Fecha (decorativa) -->
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="Hoy"
                                   FontSize="12"
                                   TextColor="#8E8E93"
                                   VerticalOptions="Center"/>

                            <!-- Contenido -->
                            <Label Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="{Binding Contenido}"
                                   FontSize="14"
                                   TextColor="#8E8E93"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2"
                                   Margin="0,4,0,10"/>

                            <!-- Separador -->
                            <BoxView Grid.Row="2" Grid.ColumnSpan="2"
                                     HeightRequest="1"
                                     BackgroundColor="#F2F2F7"
                                     Margin="0,0,0,10"/>

                            <!-- Botones -->
                            <HorizontalStackLayout Grid.Row="3" Grid.ColumnSpan="2"
                                                   Spacing="10">

                                <Frame BackgroundColor="#EAF4FF"
                                       BorderColor="Transparent"
                                       CornerRadius="10"
                                       Padding="0"
                                       HasShadow="False">
                                    <Button Text="✎  Editar"
                                            BackgroundColor="Transparent"
                                            TextColor="#007AFF"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            HeightRequest="36"
                                            Padding="16,0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditarCommand}"
                                            CommandParameter="{Binding .}"/>
                                </Frame>

                                <Frame BackgroundColor="#FFECEC"
                                       BorderColor="Transparent"
                                       CornerRadius="10"
                                       Padding="0"
                                       HasShadow="False">
                                    <Button Text="🗑  Eliminar"
                                            BackgroundColor="Transparent"
                                            TextColor="#FF3B30"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            HeightRequest="36"
                                            Padding="16,0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EliminarCommand}"
                                            CommandParameter="{Binding .}"/>
                                </Frame>

                            </HorizontalStackLayout>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>